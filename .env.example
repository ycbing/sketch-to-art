# ====================
# Database
# ====================
DATABASE_URL=postgresql://user:password@localhost:5432/sketch_to_art

# ====================
# Auth
# ====================
NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=http://localhost:3006  # Set this when deploying to your domain

# ====================
# Image Provider
# ====================
# Which provider to use: cogview (default), dalle, stability
# Leave empty to auto-detect based on available API keys
IMAGE_PROVIDER=cogview

# --- CogView (ZhipuAI) ---
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
IMAGE_MODEL=cogview-3-plus

# --- OpenAI DALL-E ---
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# DALLE_MODEL=dall-e-3

# --- Stability AI ---
# STABILITY_API_KEY=your-stability-api-key

# ====================
# GitHub OAuth (optional, for social login)
# ====================
# GITHUB_ID=your-github-client-id
# GITHUB_SECRET=your-github-client-secret

# ====================
# App URL (change to your domain when deploying)
# ====================
# NEXTAUTH_URL=https://your-domain.com

# ====================
# Tencent Cloud COS (optional, images stored as temp URLs if not configured)
# ====================
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=your-bucket
COS_REGION=ap-shanghai